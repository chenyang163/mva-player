          ]
        },
        "scale": {
          "keyframes": [
            { "time": 0.0, "value": { "x": 0.95, "y": 0.95 }, "easing": { "named": "ease_out_cubic" } },
            { "time": 0.8, "value": { "x": 1.0, "y": 1.0 }, "easing": "hold" }
          ]
        }
      },
      "visible_range": [0.0, 126.0],
      "blend_mode": "normal"
    }
  ]
}

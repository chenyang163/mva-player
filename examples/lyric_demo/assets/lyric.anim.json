{
  "layers": [
    {
      "id": "lyric-text",
      "name": "Lyric",
      "kind": {
        "type": "text",
        "source": { "type": "lyric_line" },
        "style": {
          "font_family": null,
          "font_size": 42.0,
          "color": [255, 255, 255, 255]
        }
      },
      "transform": {
